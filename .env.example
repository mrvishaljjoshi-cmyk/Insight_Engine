# Insight Engine - Environment Configuration Example
# Copy this file to .env and fill in your values

# ============================================
# CORE SETTINGS
# ============================================
PROJECT_NAME=Insight
ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ============================================
# DATABASE
# ============================================
# Development (SQLite)
# DATABASE_URL=sqlite:///./insight.db

# Production (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/insight_db

# ============================================
# SECURITY
# ============================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-32-byte-urlsafe-base64-key-here

# ============================================
# REDIS
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# OAUTH (Optional)
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# SMTP (For password reset emails)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@example.com

# ============================================
# BROKER API KEYS (Optional - for live trading)
# ============================================
# Zerodha
ZERODHA_API_KEY=
ZERODHA_API_SECRET=

# Angel One
ANGEL_ONE_API_KEY=
ANGEL_ONE_CLIENT_ID=
ANGEL_ONE_PASSWORD=

# Groww
GROWW_API_KEY=
GROWW_API_SECRET=

# ============================================
# SERVER
# ============================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001
FRONTEND_PORT=8081